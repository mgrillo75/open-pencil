{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "open-pencil-collab",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-26",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "CollabRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CollabRoom"]
    }
  ],
  "routes": [
    {
      "pattern": "collab.openpencil.dev",
      "custom_domain": true
    }
  ]
}
